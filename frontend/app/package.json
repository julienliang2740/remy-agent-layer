{
  "name": "remy-app",
  "private": true,
  "version": "0.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port 8082",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "node --stack-size=8000 node_modules/typescript/bin/tsc --noEmit",
    "eval:grip": "tsx eval/gripEval.ts",
    "e2e": "expo export --platform web --output-dir dist-web && playwright test",
    "eval:action": "tsx eval/actionEval.ts"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/instrument-sans": "^0.4.1",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "expo": "~54.0.0",
    "expo-font": "~14.0.0",
    "expo-image-picker": "~17.0.0",
    "expo-linear-gradient": "~15.0.0",
    "expo-status-bar": "~3.0.0",
    "lucide-react-native": "^0.575.0",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "~19.1.10",
    "serve": "^14.2.6",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2"
  }
}
