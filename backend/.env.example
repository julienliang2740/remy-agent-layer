# Copy to .env and fill in. The mock detector needs NONE of this — it works offline.
# These keys live on the SERVER only. Your website/app users never need a key.

# --- Free tier (recommended for deploy) ---
# Google Gemini. Free key: https://aistudio.google.com/apikey
# When set, detection + recipes use Gemini automatically.
GEMINI_API_KEY=
# Gemini model. Default: gemini-2.5-flash (free tier, good vision).
GEMINI_MODEL=

# --- Paid (higher quality / fallback) ---
# Anthropic Claude. Used if GEMINI_API_KEY is not set.
ANTHROPIC_API_KEY=
# Claude model. Default: claude-opus-4-8. Cheaper: claude-sonnet-4-6, claude-haiku-4-5.
REMY_MODEL=

# OpenAI. Used if neither Gemini nor Anthropic is configured.
OPENAI_API_KEY=
# OpenAI model. Default: gpt-5.4-nano.
OPENAI_MODEL=

# --- Overrides ---
# Force a detector: "gemini" | "claude" | "openai" | "mock".
# Auto: Gemini, then Anthropic, then OpenAI by key presence; otherwise mock.
REMY_DETECTOR=

# Port for `npm run serve`.
PORT=8787
