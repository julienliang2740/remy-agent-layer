# Base URL of the Remy backend agent layer (the /detect, /recipe, /reviews API).
# Copy to .env and point at your backend. Defaults to localhost when unset.
#
#   local dev:   http://localhost:8787   (run `npm run serve` in ../../backend)
#   deployed:    https://your-remy-backend.example.com
#
# Must be EXPO_PUBLIC_ prefixed to be readable in the Expo web/app bundle.
EXPO_PUBLIC_REMY_API=http://localhost:8787
